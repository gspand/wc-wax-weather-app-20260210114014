# =============================================================================
# Bikepacking Diary – Umgebungsvariablen
#
# Kopiere diese Datei nach .env und passe alle Werte an:
#   cp .env.example .env
#   chmod 600 .env
#   nano .env
#
# NIEMALS die .env-Datei committen – sie ist in .gitignore eingetragen.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=bpdiary
POSTGRES_USER=bpdiary

# Sicheres Passwort erzeugen: openssl rand -base64 32
POSTGRES_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# -----------------------------------------------------------------------------
# Flask-Anwendung
# -----------------------------------------------------------------------------

# Sicheren Key erzeugen: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_SECURE_SECRET_KEY

FLASK_ENV=production
DEMO_MODE=false

# -----------------------------------------------------------------------------
# Strava OAuth
# Erstelle eine App auf: https://www.strava.com/settings/api
# -----------------------------------------------------------------------------
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_CALLBACK_URL=https://diary-api.skybasevario.com/strava/callback

# Webhook Verify Token (beliebiger sicherer String)
# Erzeugen: openssl rand -hex 16
STRAVA_WEBHOOK_VERIFY_TOKEN=REPLACE_WITH_WEBHOOK_VERIFY_TOKEN

# -----------------------------------------------------------------------------
# Garmin Connect (optional)
# -----------------------------------------------------------------------------
GARMIN_USERNAME=
GARMIN_PASSWORD=
GARMIN_START_DATE=2026-06-27

# -----------------------------------------------------------------------------
# Karten-Provider
# Optionen: osm | google
# -----------------------------------------------------------------------------
MAP_PROVIDER=osm
GOOGLE_MAPS_API_KEY=
MAP_LANGUAGE=de-DE
MAP_REGION=AT
