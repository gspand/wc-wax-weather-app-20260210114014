SECRET_KEY=change-me-locally
DEMO_MODE=1
MAP_PROVIDER=osm
GOOGLE_MAPS_API_KEY=
MAP_LANGUAGE=de-DE
MAP_REGION=AT

# Strava OAuth (required for Strava integration)
# Obtain from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Must match the "Authorization Callback Domain" in your Strava API application
# Example: http://localhost:5000/strava/callback
STRAVA_CALLBACK_URL=http://localhost:5000/strava/callback
# A random secret token used to verify Strava webhook subscriptions
STRAVA_WEBHOOK_VERIFY_TOKEN=
